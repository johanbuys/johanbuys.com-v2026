---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header id="site-header">
  <nav>
    <div class="nav-left">
      <a href="/" class="logo" transition:name="logo">
        <div class="logo-box">
          <span class="logo-text">JB</span>
        </div>
        <div class="logo-dot"></div>
      </a>
      <span class="logo-name">{SITE_TITLE}</span>
      <span class="rev-label">REV 2026</span>
    </div>

    <div class="nav-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/notes">Notes</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/journey">Journey</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>

    <div class="nav-right">
      <a href="https://www.linkedin.com/in/johan-buys/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-link">
        <span class="sr-only">Connect with Johan on LinkedIn</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16"
          ><path
            fill="currentColor"
            d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
          ></path></svg
        >
      </a>
      <a href="https://github.com/johanbuys" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="social-link">
        <span class="sr-only">Go to Johan's GitHub repo</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16"
          ><path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path></svg
        >
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="menuBtn" class="menu-btn" aria-label="Toggle menu">
      <div class="menu-line" id="menuLine1"></div>
      <div class="menu-line" id="menuLine2"></div>
      <div class="menu-line menu-line-short" id="menuLine3"></div>
    </button>
  </nav>

  <!-- Mobile Nav -->
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu-inner">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/notes">Notes</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/journey">Journey</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <div class="mobile-social">
        <a href="https://www.linkedin.com/in/johan-buys/" target="_blank" rel="noopener noreferrer" class="social-link">
          <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16"><path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"></path></svg>
        </a>
        <a href="https://github.com/johanbuys" target="_blank" rel="noopener noreferrer" class="social-link">
          <svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    margin: 0;
    padding: 0;
    background: rgba(237, 242, 250, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1152px;
    margin: 0 auto;
    padding: 0 1rem;
    height: 64px;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo {
    position: relative;
    display: flex;
    text-decoration: none;
  }

  .logo-box {
    width: 32px;
    height: 32px;
    border: 2px solid var(--navy);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color var(--transition-fast);
  }

  .logo:hover .logo-box {
    border-color: var(--accent);
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .logo-dot {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 8px;
    height: 8px;
    background: var(--accent);
    border-radius: 50%;
  }

  .logo-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text);
  }

  .rev-label {
    display: none;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.15em;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5em;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 4px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .social-link:hover {
    color: var(--accent);
    background: var(--accent-glow);
  }

  /* Mobile menu button */
  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 8px;
    background: none;
    border: none;
    cursor: pointer;
  }

  .menu-line {
    width: 20px;
    height: 2px;
    background: var(--navy);
    transition: all 0.3s ease;
  }

  .menu-line-short {
    width: 12px;
  }

  /* Mobile menu panel */
  .mobile-menu {
    display: none;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .mobile-menu.open {
    max-height: 400px;
  }

  .mobile-menu-inner {
    padding: 0.5rem 1rem 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-social {
    display: flex;
    gap: 0.5em;
    margin-top: 0.5em;
    padding-top: 0.75em;
    border-top: 1px solid var(--border);
  }

  /* Scrolled state */
  header.scrolled {
    border-bottom-color: rgba(230, 57, 70, 0.2);
    box-shadow: 0 1px 12px rgba(27, 42, 74, 0.08);
  }

  @media (min-width: 768px) {
    nav {
      padding: 0 1.5rem;
    }

    .rev-label {
      display: inline-block;
    }
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }

    .nav-right {
      display: none;
    }

    .menu-btn {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }

    .logo-name {
      display: none;
    }
  }
</style>

<script is:inline>
  function initHeader() {
    var h = document.getElementById('site-header');
    if (!h) return;

    // Scroll detection
    function onScroll() {
      if (window.scrollY > 20) {
        h.classList.add('scrolled');
      } else {
        h.classList.remove('scrolled');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    // Mobile menu toggle
    var menuBtn = document.getElementById('menuBtn');
    var mobileMenu = document.getElementById('mobileMenu');
    var menuLine1 = document.getElementById('menuLine1');
    var menuLine2 = document.getElementById('menuLine2');
    var menuLine3 = document.getElementById('menuLine3');
    var menuOpen = false;

    if (menuBtn && mobileMenu && !menuBtn.dataset.bound) {
      menuBtn.dataset.bound = 'true';
      menuBtn.addEventListener('click', function() {
        menuOpen = !menuOpen;
        mobileMenu.classList.toggle('open');
        if (menuOpen) {
          menuLine1.style.transform = 'rotate(45deg) translate(2px, 2px)';
          menuLine2.style.opacity = '0';
          menuLine3.style.transform = 'rotate(-45deg) translate(2px, -2px)';
          menuLine3.style.width = '20px';
        } else {
          menuLine1.style.transform = 'none';
          menuLine2.style.opacity = '1';
          menuLine3.style.transform = 'none';
          menuLine3.style.width = '12px';
        }
      });
    }
  }
  document.addEventListener('astro:page-load', initHeader);
  initHeader();
</script>
