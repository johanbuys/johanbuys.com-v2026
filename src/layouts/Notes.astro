---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"notes">["data"];

const { title, pubDate } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={"Notes"} />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0 auto;
      }

      .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 2em;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 2px;
        box-shadow: var(--shadow-sm);
        margin-top: 1.5em;
        margin-bottom: 2em;
      }

      .article-header {
        margin-bottom: 2.5em;
        padding: 2em 0 1.5em;
        border-bottom: 1px solid var(--border);
      }

      .article-header h1 {
        font-size: 2em;
        line-height: 1.15;
        letter-spacing: -0.03em;
        margin: 0.5em 0 0;
      }

      .date-info {
        font-family: var(--font-mono);
        font-size: 0.68em;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      @media (max-width: 720px) {
        main {
          width: calc(100% - 1em);
        }

        .article-header h1 {
          font-size: 1.4em;
        }

        .prose {
          max-width: 100%;
          padding: 1.25em;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="prose">
          <div class="article-header" style="animation: fadeInUp 0.5s ease-out both;">
            <div class="date-info">
              <FormattedDate date={pubDate} />
            </div>
            <h1>{title}</h1>
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
