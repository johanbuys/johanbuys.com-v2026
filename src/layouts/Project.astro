---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'projects'>['data'];

const { title, description, pubDate, heroImage, tags, url, techStack, featured } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0 auto;
			}

			.hero-image {
				width: 100%;
				max-width: 960px;
				margin: 0 auto;
				padding: 0 1em;
			}

			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 2px;
				border: 1px solid var(--border);
				transition: border-color var(--transition);
			}

			.hero-image img:hover {
				border-color: var(--accent);
			}

			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 2px;
				box-shadow: var(--shadow-sm);
				margin-top: 1.5em;
				margin-bottom: 2em;
			}

			.article-header {
				margin-bottom: 1.5em;
				padding: 2em 0 1.5em;
				border-bottom: 1px solid var(--border);
			}

			.article-header h1 {
				font-size: 2.2em;
				line-height: 1.12;
				letter-spacing: -0.03em;
				margin: 0.5em 0 0;
			}

			.date-info {
				font-family: var(--font-mono);
				font-size: 0.68em;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--text-muted);
				display: flex;
				align-items: center;
				gap: 1em;
			}

			.featured-badge {
				font-family: var(--font-mono);
				font-size: 1em;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--bg-white);
				background: var(--accent);
				padding: 0.15em 0.5em;
				border-radius: 2px;
			}

			/* Meta section */
			.meta {
				position: relative;
				margin-bottom: 2.5em;
				padding: 1.5em;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 2px;
				display: flex;
				flex-direction: column;
				gap: 1.25em;
			}

			/* Grid overlay on meta */
			.meta::after {
				content: '';
				position: absolute;
				inset: 0;
				background-image:
					linear-gradient(var(--line-light) 1px, transparent 1px),
					linear-gradient(90deg, var(--line-light) 1px, transparent 1px);
				background-size: 20px 20px;
				opacity: 0.15;
				pointer-events: none;
				border-radius: inherit;
			}

			.meta-section {
				position: relative;
				z-index: 1;
			}

			.meta-section h3 {
				font-family: var(--font-mono);
				font-size: 0.65em;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--text-muted);
				margin: 0 0 0.6em 0;
			}

			.external-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				color: var(--accent);
				text-decoration: none;
				font-family: var(--font-mono);
				font-size: 0.85em;
				font-weight: 500;
				transition: color var(--transition-fast);
			}

			.external-link:hover {
				color: var(--accent-light);
			}

			.external-link::after {
				content: '\2197';
				font-size: 1.1em;
				display: inline-block;
				transition: transform 0.2s ease;
			}

			.external-link:hover::after {
				transform: translate(2px, -2px);
			}

			.tags, .tech-stack {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.tag {
				font-family: var(--font-mono);
				font-size: 0.7em;
				font-weight: 500;
				color: var(--accent);
				background: var(--accent-glow);
				padding: 0.25em 0.65em;
				border-radius: 2px;
				border: 1px solid var(--accent-glow-strong);
			}

			.tech-item {
				font-family: var(--font-mono);
				font-size: 0.7em;
				font-weight: 500;
				color: var(--text-secondary);
				background: var(--bg);
				border: 1px solid var(--border);
				padding: 0.25em 0.65em;
				border-radius: 2px;
			}

			@media (max-width: 720px) {
				main {
					width: calc(100% - 1em);
				}

				.article-header h1 {
					font-size: 1.4em;
				}

				.prose {
					max-width: 100%;
					padding: 1.25em;
				}

				.hero-image {
					padding: 0;
				}

				.meta {
					padding: 1em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image" style="animation: fadeIn 0.5s ease-out both;">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="article-header" style="animation: fadeInUp 0.5s ease-out 0.15s both;">
						<div class="date-info">
							<FormattedDate date={pubDate} />
							{featured && <span class="featured-badge">Featured</span>}
						</div>
						<h1>{title}</h1>
					</div>
					<div class="meta">
						{url && (
							<div class="meta-section">
								<h3>Project Link</h3>
								<a href={url} class="external-link" target="_blank" rel="noopener noreferrer">
									Visit Project
								</a>
							</div>
						)}
						{tags.length > 0 && (
							<div class="meta-section">
								<h3>Tags</h3>
								<ul class="tags">
									{tags.map((tag) => (
										<li class="tag">{tag}</li>
									))}
								</ul>
							</div>
						)}
						{techStack.length > 0 && (
							<div class="meta-section">
								<h3>Tech Stack</h3>
								<ul class="tech-stack">
									{techStack.map((tech) => (
										<li class="tech-item">{tech}</li>
									))}
								</ul>
							</div>
						)}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
