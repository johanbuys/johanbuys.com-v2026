---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("notes")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Notes - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <div class="section-label">
          <span class="section-label-text">Notes</span>
        </div>
        <h1>Notes</h1>
        <p>Brief technical notes, learnings, and references.</p>
      </div>

      <section class="notes-list reveal-stagger reveal">
        {
          posts.map((post, index) => (
            <a href={`/notes/${post.id}/`} class="note-item">
              <div class="note-marker">
                <span class="note-diamond"></span>
              </div>
              <div class="note-content">
                <h3 class="note-title">{post.data.title}</h3>
              </div>
              <span class="note-date">
                <FormattedDate date={post.data.pubDate} />
              </span>
            </a>
          ))
        }
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: auto;
    padding: 3em 1em;
  }

  .page-header {
    margin-bottom: 2.5em;
    animation: fadeIn 0.5s ease-out both;
  }

  .page-header h1 {
    margin-top: 0.5em;
    margin-bottom: 0.25em;
  }

  .page-header p {
    font-size: 1.05em;
    color: var(--text-muted);
    margin: 0;
    font-family: var(--font-serif);
  }

  .section-label-text {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    padding-left: 0.5rem;
  }

  .notes-list {
    display: flex;
    flex-direction: column;
  }

  .note-item {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: 0.85em 0;
    padding-left: 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .note-item:first-child {
    border-top: 1px solid var(--border);
  }

  .note-item:hover {
    padding-left: 0.75em;
    background: linear-gradient(90deg, var(--accent-glow), transparent 40%);
  }

  .note-marker {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
  }

  .note-diamond {
    display: block;
    width: 8px;
    height: 8px;
    border: 1.5px solid var(--accent);
    transform: rotate(45deg);
    transition: all 0.2s ease;
  }

  .note-item:hover .note-diamond {
    background: var(--accent);
    transform: rotate(45deg) scale(1.2);
  }

  .note-content {
    flex-grow: 1;
    min-width: 0;
  }

  .note-title {
    font-family: var(--font-mono);
    font-size: 0.95em;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    transition: color var(--transition-fast);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .note-item:hover .note-title {
    color: var(--accent);
  }

  .note-date {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.65em;
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  @media (max-width: 720px) {
    main {
      padding: 1.5em 1em;
    }

    .note-item {
      flex-wrap: wrap;
      gap: 0.5em;
    }

    .note-date {
      width: 100%;
      padding-left: calc(20px + 1em);
    }
  }
</style>
