---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("notes")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Notes - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <h1>Notes</h1>
        <p>Brief technical notes, learnings, and references.</p>
      </div>

      <section class="notes-list reveal-stagger reveal">
        {
          posts.map((post, index) => (
            <a href={`/notes/${post.id}/`} class="note-item">
              <div class="note-marker">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                  <path d="M3 2h7l3 3v9H3V2z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                  <path d="M10 2v3h3" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                  <path d="M5 8h6M5 10.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
              </div>
              <div class="note-content">
                <h3 class="note-title">{post.data.title}</h3>
              </div>
              <span class="note-date">
                <FormattedDate date={post.data.pubDate} />
              </span>
            </a>
          ))
        }
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 720px;
    max-width: calc(100% - 2em);
    margin: auto;
    padding: 3em 1em;
  }

  .page-header {
    margin-bottom: 2.5em;
    animation: fadeIn 0.5s var(--ease-out) both;
  }

  .page-header h1 {
    margin-bottom: 0.25em;
  }

  .page-header p {
    font-size: 1.05em;
    color: var(--text-muted);
    margin: 0;
  }

  .notes-list {
    display: flex;
    flex-direction: column;
  }

  .note-item {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: 1em 0;
    padding-left: 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: all 0.2s var(--ease-out);
  }

  .note-item:first-child {
    border-top: 1px solid var(--border);
  }

  .note-item:hover {
    padding-left: 0.75em;
    background: linear-gradient(90deg, var(--accent-glow), transparent 40%);
  }

  .note-marker {
    flex-shrink: 0;
    color: var(--text-muted);
    transition: all 0.2s var(--ease-out);
    display: flex;
    align-items: center;
  }

  .note-item:hover .note-marker {
    color: var(--accent);
    transform: translateX(2px) scale(1.1);
  }

  .note-content {
    flex-grow: 1;
    min-width: 0;
  }

  .note-title {
    font-family: var(--font-heading);
    font-size: 1.05em;
    font-weight: 600;
    color: var(--text);
    margin: 0;
    transition: color var(--transition-fast);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .note-item:hover .note-title {
    color: var(--accent);
  }

  .note-date {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.72em;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 720px) {
    main {
      padding: 1.5em 1em;
    }

    .note-item {
      flex-wrap: wrap;
      gap: 0.5em;
    }

    .note-date {
      width: 100%;
      padding-left: calc(16px + 1em);
    }
  }
</style>
