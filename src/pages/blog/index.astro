---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Blog - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <div class="section-label">
          <span class="section-label-text">Blog</span>
        </div>
        <h1>Blog</h1>
        <p>Thoughts on engineering leadership, architecture, and building teams.</p>
      </div>

      {posts.length > 0 && (
        <section class="featured reveal">
          <a href={`/blog/${posts[0].id}/`} class="featured-card spec-card">
            <div class="card-grid-overlay"></div>
            {posts[0].data.heroImage && (
              <div class="featured-image">
                <Image
                  width={960}
                  height={480}
                  src={posts[0].data.heroImage}
                  alt=""
                />
              </div>
            )}
            <div class="featured-content">
              <span class="date-label">
                <FormattedDate date={posts[0].data.pubDate} />
              </span>
              <h2 class="featured-title">{posts[0].data.title}</h2>
              <p class="featured-desc">{posts[0].data.description}</p>
              <span class="read-more">Read article <span class="arrow">&rarr;</span></span>
            </div>
          </a>
        </section>
      )}

      {posts.length > 1 && (
        <div class="dimension-line reveal">
          <div class="end-mark-left"></div>
          <span class="dim-label">All Posts</span>
          <div class="end-mark-right"></div>
        </div>

        <section class="posts reveal-stagger reveal">
          {posts.slice(1).map((post) => (
            <a href={`/blog/${post.id}/`} class="post-card spec-card">
              <div class="card-grid-overlay"></div>
              {post.data.heroImage && (
                <div class="post-image">
                  <Image
                    width={400}
                    height={260}
                    src={post.data.heroImage}
                    alt=""
                  />
                </div>
              )}
              <div class="post-content">
                <span class="date-label">
                  <FormattedDate date={post.data.pubDate} />
                </span>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-desc">{post.data.description}</p>
              </div>
            </a>
          ))}
        </section>
      )}
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 960px;
    max-width: calc(100% - 2em);
    margin: auto;
    padding: 3em 1em;
  }

  .page-header {
    margin-bottom: 3em;
    animation: fadeIn 0.5s ease-out both;
  }

  .page-header h1 {
    margin-top: 0.5em;
    margin-bottom: 0.25em;
  }

  .page-header p {
    font-size: 1.05em;
    color: var(--text-muted);
    margin: 0;
    font-family: var(--font-serif);
  }

  .section-label-text {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    padding-left: 0.5rem;
  }

  .date-label {
    font-family: var(--font-mono);
    font-size: 0.68em;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* Featured post */
  .featured {
    margin-bottom: 2em;
  }

  .featured-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .featured-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent-light), transparent);
    transition: width 0.6s ease;
    z-index: 1;
  }

  .featured-card:hover::after {
    width: 100%;
  }

  .featured-image {
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    transition: transform var(--transition-slow);
  }

  .featured-card:hover .featured-image img {
    transform: scale(1.03);
  }

  .featured-content {
    position: relative;
    z-index: 10;
    padding: 1.5em;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .featured-title {
    font-size: 1.5em;
    line-height: 1.2;
    color: var(--text);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .featured-card:hover .featured-title {
    color: var(--accent);
  }

  .featured-desc {
    font-family: var(--font-serif);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .read-more {
    font-family: var(--font-mono);
    font-size: 0.72em;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 0.5em;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }

  .read-more .arrow {
    display: inline-block;
    transition: transform 0.3s ease;
  }

  .featured-card:hover .read-more .arrow {
    transform: translateX(5px);
  }

  /* Regular posts */
  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.25em;
    padding-top: 1em;
  }

  .post-card {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .post-card::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transition: transform 0.3s ease;
  }

  .post-card:hover::after {
    transform: scaleY(1);
  }

  .post-image {
    flex-shrink: 0;
    width: 280px;
    overflow: hidden;
    display: flex;
    align-items: center;
    background: var(--bg);
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform var(--transition-slow);
  }

  .post-card:hover .post-image img {
    transform: scale(1.05);
  }

  .post-content {
    position: relative;
    z-index: 10;
    flex-grow: 1;
    padding: 1.25em;
    display: flex;
    flex-direction: column;
    gap: 0.4em;
  }

  .post-title {
    font-size: 1.1em;
    line-height: 1.3;
    color: var(--text);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .post-card:hover .post-title {
    color: var(--accent);
  }

  .post-desc {
    font-family: var(--font-serif);
    color: var(--text-secondary);
    font-size: 0.9em;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  /* Responsive */
  @media (min-width: 640px) {
    .featured-content {
      padding: 2em;
    }

    .featured-title {
      font-size: 1.8em;
    }

    .post-content {
      padding: 1.5em;
    }
  }

  @media (max-width: 720px) {
    main {
      padding: 1.5em 1em;
    }

    .post-card {
      flex-direction: column;
    }

    .post-image {
      width: 100%;
      height: 180px;
    }
  }
</style>
