---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredProject = allProjects.find((project) => project.data.featured);
const regularProjects = allProjects.filter(
  (project) => project !== featuredProject
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Projects - ${SITE_TITLE}`}
      description={SITE_DESCRIPTION}
    />
  </head>
  <body>
    <Header />
    <main>
      <div class="page-header">
        <h1>Projects</h1>
        <p>Technical work, case studies, and side projects.</p>
      </div>

      {
        featuredProject && (
          <section class="featured-section reveal">
            <a href={`/projects/${featuredProject.id}/`} class="featured-card">
              {featuredProject.data.heroImage && (
                <div class="featured-image">
                  <Image
                    width={960}
                    height={400}
                    src={featuredProject.data.heroImage}
                    alt={featuredProject.data.title}
                  />
                </div>
              )}
              <div class="featured-content">
                <div class="featured-meta">
                  <span class="date-label">
                    <FormattedDate date={featuredProject.data.pubDate} />
                  </span>
                  <span class="featured-badge">Featured</span>
                </div>
                <h2 class="featured-title">
                  {featuredProject.data.title}
                  {featuredProject.data.url && (
                    <span class="ext-icon">&nearr;</span>
                  )}
                </h2>
                <p class="featured-desc">{featuredProject.data.description}</p>
                {featuredProject.data.techStack.length > 0 && (
                  <div class="tech-stack">
                    {featuredProject.data.techStack.map((tech) => (
                      <span class="tech-item">{tech}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </section>
        )
      }

      {
        regularProjects.length > 0 && (
          <section class="projects-section">
            <h2 class="section-label">All Projects</h2>
            <div class="project-grid reveal-stagger reveal">
              {regularProjects.map((project, index) => (
                <a href={`/projects/${project.id}/`} class="project-card" style={`animation-delay: ${index * 0.08}s`}>
                  {project.data.heroImage && (
                    <div class="project-image">
                      <Image
                        width={480}
                        height={320}
                        src={project.data.heroImage}
                        alt={project.data.title}
                      />
                    </div>
                  )}
                  <div class="project-content">
                    <span class="date-label">
                      <FormattedDate date={project.data.pubDate} />
                    </span>
                    <h3 class="project-title">
                      {project.data.title}
                      {project.data.url && (
                        <span class="ext-icon">&nearr;</span>
                      )}
                    </h3>
                    <p class="project-desc">{project.data.description}</p>
                    <div class="project-footer">
                      {project.data.tags.length > 0 && (
                        <div class="tags">
                          {project.data.tags.map((tag) => (
                            <span class="tag">{tag}</span>
                          ))}
                        </div>
                      )}
                      {project.data.techStack.length > 0 && (
                        <div class="tech-stack">
                          {project.data.techStack.map((tech) => (
                            <span class="tech-item">{tech}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: 960px;
    max-width: calc(100% - 2em);
    margin: auto;
    padding: 3em 1em;
  }

  .page-header {
    margin-bottom: 3em;
    animation: fadeIn 0.5s var(--ease-out) both;
  }

  .page-header h1 {
    margin-bottom: 0.25em;
  }

  .page-header p {
    font-size: 1.05em;
    color: var(--text-muted);
    margin: 0;
  }

  /* Shared */
  .date-label {
    font-family: var(--font-mono);
    font-size: 0.72em;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .ext-icon {
    display: inline-block;
    font-size: 0.65em;
    opacity: 0.5;
    margin-left: 0.25em;
    vertical-align: super;
    transition: all 0.2s var(--ease-out);
  }

  .featured-card:hover .ext-icon,
  .project-card:hover .ext-icon {
    opacity: 1;
    transform: translate(2px, -2px);
  }

  /* Featured */
  .featured-section {
    margin-bottom: 4em;
  }

  .featured-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition);
  }

  .featured-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--accent-bright), transparent);
    transition: width 0.6s var(--ease-out);
    z-index: 1;
  }

  .featured-card:hover::before {
    width: 100%;
  }

  .featured-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md), var(--shadow-glow);
    transform: translateY(-2px);
  }

  .featured-image {
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0;
    transition: transform var(--transition-slow);
  }

  .featured-card:hover .featured-image img {
    transform: scale(1.03);
  }

  .featured-content {
    padding: 2em;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .featured-meta {
    display: flex;
    align-items: center;
    gap: 0.75em;
  }

  .featured-badge {
    font-family: var(--font-mono);
    font-size: 0.65em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--bg-deep);
    background: var(--accent);
    padding: 0.2em 0.6em;
    border-radius: 4px;
  }

  .featured-title {
    font-size: 1.8em;
    line-height: 1.2;
    color: var(--text);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .featured-card:hover .featured-title {
    color: var(--accent);
  }

  .featured-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* Section label */
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.5em;
    padding-bottom: 0.75em;
    border-bottom: 1px solid var(--border);
  }

  /* Project grid */
  .project-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25em;
  }

  .project-card {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition);
  }

  .project-card::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transition: transform 0.3s var(--ease-out);
  }

  .project-card:hover::after {
    transform: scaleY(1);
  }

  .project-card:hover {
    border-color: var(--border-hover);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }

  .project-image {
    flex-shrink: 0;
    width: 280px;
    overflow: hidden;
    display: flex;
    align-items: center;
    background: var(--bg-deep);
  }

  .project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 0;
    transition: transform var(--transition-slow);
  }

  .project-card:hover .project-image img {
    transform: scale(1.05);
  }

  .project-content {
    flex-grow: 1;
    padding: 1.5em;
    display: flex;
    flex-direction: column;
    gap: 0.4em;
  }

  .project-title {
    font-size: 1.2em;
    line-height: 1.3;
    color: var(--text);
    margin: 0;
    transition: color var(--transition-fast);
  }

  .project-card:hover .project-title {
    color: var(--accent);
  }

  .project-desc {
    color: var(--text-secondary);
    font-size: 0.9em;
    line-height: 1.6;
    margin: 0;
    flex-grow: 1;
  }

  .project-footer {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
    margin-top: 0.5em;
  }

  /* Tags & Tech Stack */
  .tags, .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4em;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.68em;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-glow);
    padding: 0.2em 0.6em;
    border-radius: 4px;
    border: 1px solid rgba(200, 162, 78, 0.2);
    transition: all var(--transition-fast);
  }

  .project-card:hover .tag,
  .featured-card:hover .tag {
    background: var(--accent-glow-strong);
    border-color: rgba(200, 162, 78, 0.4);
  }

  .tech-item {
    font-family: var(--font-mono);
    font-size: 0.68em;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    background: var(--bg-deep);
    border: 1px solid var(--border);
    padding: 0.2em 0.6em;
    border-radius: 4px;
    transition: all var(--transition-fast);
  }

  .project-card:hover .tech-item,
  .featured-card:hover .tech-item {
    border-color: var(--border-hover);
    color: var(--text-secondary);
  }

  /* Responsive */
  @media (max-width: 720px) {
    main {
      padding: 1.5em 1em;
    }

    .featured-content {
      padding: 1.5em;
    }

    .featured-title {
      font-size: 1.4em;
    }

    .project-card {
      flex-direction: column;
    }

    .project-image {
      width: 100%;
      height: 180px;
    }

    .project-content {
      padding: 1.25em;
    }

    .tags, .tech-stack {
      gap: 0.3em;
    }
  }
</style>
