---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>

      <!-- ======== HERO ======== -->
      <section class="hero">
        <!-- Crosshair decorations -->
        <div class="crosshair hero-crosshair-tl">
          <div class="crosshair-circle"></div>
        </div>
        <div class="crosshair hero-crosshair-br" style="animation-delay: 1.5s;">
          <div class="crosshair-circle"></div>
        </div>

        <!-- Spec label -->
        <div class="hero-spec animate-entrance delay-3">
          <span class="rev-label">SPEC-001</span>
        </div>

        <!-- Section annotation -->
        <div class="animate-entrance delay-1 hero-annotation">
          <div class="section-label">
            <span class="section-label-text">Engineering Leader &middot; Builder &middot; Maker</span>
          </div>
        </div>

        <!-- Hero title -->
        <h1 class="hero-title animate-entrance delay-2">
          Hi, I'm <span class="hero-name">Johan</span><span class="cursor">|</span>
        </h1>

        <!-- Intro -->
        <div class="hero-body">
          <p class="hero-intro animate-entrance delay-3">
            Former CTO &amp; technical co-founder with 20 years in tech.
            Currently leading engineering at <a
              href="https://cylinderhealth.com/"
              target="_blank"
              rel="nofollow noopener noreferrer">Cylinder Health</a>.
          </p>
          <p class="hero-sub animate-entrance delay-4">
            From IC engineer to founder to engineering manager &mdash; I build
            high-performing teams, own end-to-end product delivery, and keep my
            hands on the keyboard.
          </p>
        </div>

        <!-- Decorative dimension line -->
        <div class="hero-dim animate-entrance delay-5">
          <div class="dim-end-mark"></div>
          <div class="dim-ruler"></div>
          <span class="dim-section-label">Section 01</span>
          <div class="dim-ruler"></div>
          <div class="dim-end-mark"></div>
        </div>
      </section>

      <!-- ======== DIMENSION LINE DIVIDER ======== -->
      <div class="dimension-line reveal">
        <div class="end-mark-left"></div>
        <span class="dim-label">Core Capabilities</span>
        <div class="end-mark-right"></div>
      </div>

      <!-- ======== VALUE PROPS — 3 CARDS ======== -->
      <section class="capabilities">
        <div class="reveal cap-annotation">
          <div class="section-label">
            <span class="section-label-text">What I Bring</span>
          </div>
        </div>

        <div class="cards-grid">
          <!-- Card 1: Team Builder -->
          <div class="spec-card corner-fold card-item reveal" style="transition-delay: 0.1s;">
            <div class="card-grid-overlay"></div>
            <div class="pin"></div>
            <span class="card-seq">01/03</span>
            <div class="card-inner">
              <div class="card-heading">
                <div class="card-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                </div>
                <h3>Team Builder</h3>
              </div>
              <p>
                I hire, mentor, and grow engineering teams. Built my current team
                from scratch, doubled its size, launched an internship program, and
                promoted engineers into senior roles.
              </p>
            </div>
          </div>

          <!-- Card 2: Technical Architect -->
          <div class="spec-card corner-fold card-item reveal" style="transition-delay: 0.2s;">
            <div class="card-grid-overlay"></div>
            <div class="pin"></div>
            <span class="card-seq">02/03</span>
            <div class="card-inner">
              <div class="card-heading">
                <div class="card-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="16 18 22 12 16 6"/>
                    <polyline points="8 6 2 12 8 18"/>
                  </svg>
                </div>
                <h3>Technical Architect</h3>
              </div>
              <p>
                I design and build systems that scale. From event-driven
                microservices to HIPAA-compliant AI features, I stay hands-on
                with the architecture while leading the team.
              </p>
            </div>
          </div>

          <!-- Card 3: Product Shipper -->
          <div class="spec-card corner-fold card-item reveal" style="transition-delay: 0.3s;">
            <div class="card-grid-overlay"></div>
            <div class="pin"></div>
            <span class="card-seq">03/03</span>
            <div class="card-inner">
              <div class="card-heading">
                <div class="card-icon">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E63946" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7"/>
                    <rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/>
                  </svg>
                </div>
                <h3>Product Shipper</h3>
              </div>
              <p>
                I lead high-stakes projects to completion. From AI-powered
                product features to company rebrands, I ship cross-functional
                projects on time with quality.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ======== DIMENSION LINE DIVIDER ======== -->
      <div class="dimension-line reveal">
        <div class="end-mark-left"></div>
        <span class="dim-label">Active Projects</span>
        <div class="end-mark-right"></div>
      </div>

      <!-- ======== WHAT I'M WORKING ON ======== -->
      <section class="working-on">
        <div class="crosshair working-crosshair" style="animation-delay: 0.8s;">
          <div class="crosshair-circle"></div>
        </div>

        <div class="working-spec reveal">
          <span class="rev-label">SPEC-002</span>
        </div>

        <div class="reveal working-annotation">
          <div class="section-label">
            <span class="section-label-text">What I'm Working On</span>
          </div>
        </div>

        <div class="spec-card working-card reveal">
          <div class="card-grid-overlay"></div>
          <div class="working-items">
            <div class="work-item reveal" style="transition-delay: 0.1s;">
              <p>
                <span class="work-num">01</span>
                Building AI-powered features in a HIPAA-compliant health tech stack
              </p>
            </div>
            <div class="work-item reveal" style="transition-delay: 0.15s;">
              <p>
                <span class="work-num">02</span>
                Leading and growing an engineering team &mdash; hiring, mentoring, and promoting
              </p>
            </div>
            <div class="work-item reveal" style="transition-delay: 0.2s;">
              <p>
                <span class="work-num">03</span>
                Driving frontend and mobile product delivery across the organization
              </p>
            </div>
            <div class="work-item reveal" style="transition-delay: 0.25s;">
              <p>
                <span class="work-num">04</span>
                Modernizing CI/CD infrastructure and developer tooling
              </p>
            </div>
            <div class="work-item reveal" style="transition-delay: 0.3s;">
              <p>
                <span class="work-num">05</span>
                Establishing engineering culture through community of practice and mentorship
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ======== DIMENSION LINE DIVIDER ======== -->
      <div class="dimension-line reveal">
        <div class="end-mark-left"></div>
        <span class="dim-label">Specifications</span>
        <div class="end-mark-right"></div>
      </div>

      <!-- ======== EXPERIENCE SNAPSHOT ======== -->
      <section class="snapshot">
        <div class="crosshair snapshot-crosshair" style="animation-delay: 2s;">
          <div class="crosshair-circle"></div>
        </div>

        <div class="snapshot-spec reveal">
          <span class="rev-label">SPEC-003</span>
        </div>

        <div class="reveal snapshot-annotation">
          <div class="section-label">
            <span class="section-label-text">Experience Snapshot</span>
          </div>
        </div>

        <div class="snapshot-grid">
          <div class="spec-card snapshot-item reveal" style="transition-delay: 0.1s;">
            <div class="card-grid-overlay"></div>
            <div class="snapshot-inner">
              <div class="spec-number">20</div>
              <div class="snapshot-label">Years in Tech</div>
              <div class="snapshot-divider"></div>
              <div class="snapshot-detail">TypeScript / React<br>Node.js / Go</div>
            </div>
          </div>

          <div class="spec-card snapshot-item reveal" style="transition-delay: 0.2s;">
            <div class="card-grid-overlay"></div>
            <div class="snapshot-inner">
              <div class="spec-number">CTO</div>
              <div class="snapshot-label">Former Co-Founder</div>
              <div class="snapshot-divider"></div>
              <div class="snapshot-detail">Built ML-powered<br>platform from scratch</div>
            </div>
          </div>

          <div class="spec-card snapshot-item reveal" style="transition-delay: 0.3s;">
            <div class="card-grid-overlay"></div>
            <div class="snapshot-inner">
              <div class="spec-number">EM</div>
              <div class="snapshot-label">Engineering Manager</div>
              <div class="snapshot-divider"></div>
              <div class="snapshot-detail">Leading teams at<br>Series B startup</div>
            </div>
          </div>

          <div class="spec-card snapshot-item reveal" style="transition-delay: 0.4s;">
            <div class="card-grid-overlay"></div>
            <div class="snapshot-inner">
              <div class="spec-number">IC&rarr;L</div>
              <div class="snapshot-label">Full Career Arc</div>
              <div class="snapshot-divider"></div>
              <div class="snapshot-detail">IC &rarr; Manager<br>&rarr; Founder &rarr; Leader</div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<script is:inline>
  // Add subtle parallax to crosshairs on mouse move (desktop only)
  function initParallax() {
    if (window.matchMedia('(min-width: 1024px)').matches) {
      var crosshairs = document.querySelectorAll('.crosshair');
      document.addEventListener('mousemove', function(e) {
        var x = (e.clientX / window.innerWidth - 0.5) * 8;
        var y = (e.clientY / window.innerHeight - 0.5) * 8;
        crosshairs.forEach(function(ch, i) {
          var factor = i % 2 === 0 ? 1 : -1;
          ch.style.transform = 'translate(' + (x * factor) + 'px, ' + (y * factor) + 'px)';
        });
      });
    }
  }
  document.addEventListener('astro:page-load', initParallax);
  initParallax();
</script>

<style>
  main {
    max-width: 1152px;
    width: 100%;
    padding: 2em 1rem;
  }

  @media (min-width: 640px) {
    main {
      padding: 2em 1.5rem;
    }
  }

  /* ---- HERO ---- */
  .hero {
    position: relative;
    padding: 3em 0 4em;
    animation: fadeIn 0.6s ease-out both;
  }

  .hero-crosshair-tl {
    top: 0;
    left: -40px;
    display: none;
  }

  .hero-crosshair-br {
    bottom: 0;
    right: -40px;
    display: none;
  }

  .hero-spec {
    position: absolute;
    top: 0;
    right: 0;
  }

  .hero-annotation {
    margin-bottom: 1.5em;
  }

  .section-label-text {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 500;
    padding-left: 0.5rem;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1.5em;
    color: var(--text);
  }

  .hero-name {
    color: var(--accent);
  }

  .cursor {
    color: var(--accent);
    font-weight: 300;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-body {
    max-width: 680px;
  }

  .hero-intro {
    font-family: var(--font-serif);
    font-size: 1.15em;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1em;
  }

  .hero-intro a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent-glow-strong);
    transition: border-color var(--transition-fast);
  }

  .hero-intro a:hover {
    border-bottom-color: var(--accent);
  }

  .hero-sub {
    font-family: var(--font-serif);
    font-size: 1em;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .hero-dim {
    display: flex;
    align-items: center;
    gap: 0.5em;
    max-width: 280px;
    margin-top: 3em;
  }

  .dim-end-mark {
    width: 1px;
    height: 12px;
    background: rgba(27, 42, 74, 0.3);
  }

  .dim-ruler {
    flex: 1;
    height: 1px;
    background: rgba(27, 42, 74, 0.3);
  }

  .dim-section-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(27, 42, 74, 0.3);
    white-space: nowrap;
  }

  /* ---- CAPABILITY CARDS ---- */
  .capabilities {
    position: relative;
    padding: 3em 0 4em;
  }

  .cap-annotation {
    margin-bottom: 2em;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5em;
  }

  .card-item {
    padding: 1.5em 1.25em 1.5em 1.25em;
    padding-top: 2em;
  }

  .card-inner {
    position: relative;
    z-index: 10;
  }

  .card-heading {
    display: flex;
    align-items: center;
    gap: 0.5em;
    margin-bottom: 0.75em;
    margin-top: 0.5em;
  }

  .card-icon {
    width: 24px;
    height: 24px;
    border: 1px solid var(--accent);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-item h3 {
    font-family: var(--font-mono);
    font-size: 0.85em;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text);
    margin: 0;
  }

  .card-item p {
    font-family: var(--font-serif);
    font-size: 0.95em;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ---- WORKING ON ---- */
  .working-on {
    position: relative;
    padding: 3em 0 4em;
  }

  .working-crosshair {
    top: 20px;
    right: -40px;
    display: none;
  }

  .working-spec {
    position: absolute;
    top: 0;
    right: 0;
  }

  .working-annotation {
    margin-bottom: 2em;
  }

  .working-card {
    padding: 1.5em;
  }

  .working-items {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 1.25em;
  }

  .work-item {
    position: relative;
    padding-left: 2rem;
    transition: all 0.2s ease;
  }

  .work-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 8px;
    height: 8px;
    border: 1.5px solid var(--accent);
    transform: rotate(45deg);
    transition: all 0.2s ease;
  }

  .work-item:hover::before {
    background: var(--accent);
  }

  .work-item:hover {
    padding-left: 2.5rem;
  }

  .work-item::after {
    content: '';
    position: absolute;
    left: 12px;
    top: calc(0.65em + 4px);
    width: 1rem;
    height: 1px;
    background: var(--line);
  }

  .work-item p {
    font-family: var(--font-serif);
    font-size: 1em;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  .work-num {
    font-family: var(--font-mono);
    font-size: 0.75em;
    color: var(--accent);
    font-weight: 600;
    margin-right: 0.5em;
  }

  /* ---- SNAPSHOT ---- */
  .snapshot {
    position: relative;
    padding: 3em 0 2em;
  }

  .snapshot-crosshair {
    top: 20px;
    left: -40px;
    display: none;
  }

  .snapshot-spec {
    position: absolute;
    top: 0;
    right: 0;
  }

  .snapshot-annotation {
    margin-bottom: 2em;
  }

  .snapshot-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1em;
  }

  .snapshot-item {
    padding: 1.25em;
    text-align: center;
  }

  .snapshot-inner {
    position: relative;
    z-index: 10;
  }

  .spec-number {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 2.5em;
    line-height: 1;
    color: var(--accent);
    margin-bottom: 0.15em;
  }

  .snapshot-label {
    font-family: var(--font-mono);
    font-size: 0.72em;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5em;
  }

  .snapshot-divider {
    width: 32px;
    height: 1px;
    background: var(--accent);
    margin: 0 auto 0.5em;
  }

  .snapshot-detail {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    line-height: 1.6;
  }

  /* ---- RESPONSIVE ---- */
  @media (min-width: 640px) {
    .hero-title {
      font-size: 3rem;
    }

    .hero-intro {
      font-size: 1.2em;
    }

    .working-card {
      padding: 2em;
    }

    .work-item p {
      font-size: 1.05em;
    }

    .snapshot-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .snapshot-item {
      padding: 1.5em;
    }

    .spec-number {
      font-size: 3em;
    }
  }

  @media (min-width: 768px) {
    .cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .card-item {
      padding: 1.5em;
      padding-top: 2em;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      padding: 5em 0 6em;
    }

    .hero-title {
      font-size: 4rem;
    }

    .hero-crosshair-tl,
    .hero-crosshair-br,
    .working-crosshair,
    .snapshot-crosshair {
      display: block;
    }

    .snapshot-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .spec-number {
      font-size: 3.5em;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2rem;
    }

    .snapshot-grid {
      grid-template-columns: 1fr;
    }

    .spec-number {
      font-size: 2.5em;
    }
  }
</style>
